# Copy this file to `.env` and fill in values below.

# Discord webhook — Server Settings → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# Proxy (recommended when running on a server — use a residential proxy to avoid Cloudflare blocks).
# Format: http://host:port  or  socks5://host:port
# Leave blank to connect directly.
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
